// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum ProductStatus {
  SELLING
  RESERVED
  SOLD
  BLOCKED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  nickname     String     @unique
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)
  balance      Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  products Product[]

  sellingConversations Conversation[] @relation("SellerConversations")
  buyingConversations  Conversation[] @relation("BuyerConversations")
  messages             Message[]

  sentTransfers     Transfer[] @relation("SentTransfers")
  receivedTransfers Transfer[] @relation("ReceivedTransfers")
}

model Product {
  id          String        @id @default(cuid())
  sellerId    String
  title       String
  description String
  price       Int
  imageUrl    String?
  status      ProductStatus @default(SELLING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  seller User @relation(fields: [sellerId], references: [id], onDelete: Restrict)

  conversations Conversation[]

  @@index([sellerId])
  @@index([status, createdAt])
}

model Conversation {
  id        String   @id @default(cuid())
  productId String
  sellerId  String
  buyerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  seller  User    @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Restrict)
  buyer   User    @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Restrict)

  messages Message[]

  @@unique([productId, sellerId, buyerId])
  @@index([sellerId, updatedAt])
  @@index([buyerId, updatedAt])
  @@index([productId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Transfer {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  amount     Int
  memo       String?
  createdAt  DateTime @default(now())

  sender   User @relation("SentTransfers", fields: [senderId], references: [id], onDelete: Restrict)
  receiver User @relation("ReceivedTransfers", fields: [receiverId], references: [id], onDelete: Restrict)

  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
}
