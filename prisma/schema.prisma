// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum ProductStatus {
  SELLING
  RESERVED
  SOLD
  BLOCKED
}

enum PurchaseStatus {
  RESERVED
  COMPLETED
  CANCEL_REQUESTED
  CANCELED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ChargeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  nickname     String     @unique
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)
  balance      Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  products Product[]

  sellingConversations Conversation[] @relation("SellerConversations")
  buyingConversations  Conversation[] @relation("BuyerConversations")
  messages             Message[]

  sentTransfers     Transfer[]      @relation("SentTransfers")
  receivedTransfers Transfer[]      @relation("ReceivedTransfers")
  purchases         Purchase[]      @relation("BuyerPurchases")
  sales             Purchase[]      @relation("SellerPurchases")
  sentOffers        Offer[]         @relation("BuyerOffers")
  receivedOffers    Offer[]         @relation("SellerOffers")
  chargeRequests    ChargeRequest[]
}

model Product {
  id           String        @id @default(cuid())
  sellerId     String
  title        String
  description  String
  price        Int
  imageUrl     String?
  status       ProductStatus @default(SELLING)
  isNegotiable Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  seller User @relation(fields: [sellerId], references: [id], onDelete: Restrict)

  conversations Conversation[]
  purchases     Purchase[]
  offers        Offer[]

  @@index([sellerId])
  @@index([status, createdAt])
}

model Conversation {
  id        String   @id @default(cuid())
  productId String
  sellerId  String
  buyerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  seller  User    @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Restrict)
  buyer   User    @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Restrict)

  messages Message[]
  offers   Offer[]

  @@unique([productId, sellerId, buyerId])
  @@index([sellerId, updatedAt])
  @@index([buyerId, updatedAt])
  @@index([productId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Transfer {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  amount     Int
  memo       String?
  createdAt  DateTime @default(now())

  sender   User @relation("SentTransfers", fields: [senderId], references: [id], onDelete: Restrict)
  receiver User @relation("ReceivedTransfers", fields: [receiverId], references: [id], onDelete: Restrict)

  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
}

model Purchase {
  id                String         @id @default(cuid())
  productId         String
  buyerId           String
  sellerId          String
  amount            Int
  status            PurchaseStatus @default(RESERVED)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  completedAt       DateTime?
  cancelRequestedAt DateTime?
  canceledAt        DateTime?

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  buyer   User    @relation("BuyerPurchases", fields: [buyerId], references: [id], onDelete: Restrict)
  seller  User    @relation("SellerPurchases", fields: [sellerId], references: [id], onDelete: Restrict)

  @@index([productId, status])
  @@index([buyerId, createdAt])
  @@index([sellerId, createdAt])
}

model Offer {
  id             String      @id @default(cuid())
  productId      String
  buyerId        String
  sellerId       String
  conversationId String?
  proposedPrice  Int
  message        String?
  status         OfferStatus @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  acceptedAt     DateTime?
  rejectedAt     DateTime?

  product      Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  buyer        User          @relation("BuyerOffers", fields: [buyerId], references: [id], onDelete: Restrict)
  seller       User          @relation("SellerOffers", fields: [sellerId], references: [id], onDelete: Restrict)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([productId, status])
  @@index([buyerId, createdAt])
  @@index([sellerId, createdAt])
  @@index([conversationId])
}

model ChargeRequest {
  id         String              @id @default(cuid())
  userId     String
  amount     Int
  memo       String?
  status     ChargeRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  approvedAt DateTime?
  rejectedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}
